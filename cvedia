name: Package Docker Image to File

on:
  workflow_dispatch: # 允许你手动点击运行

jobs:
  build:
    runs-on: ubuntu-latest
    # 设置权限，允许 Action 写入 Release
    permissions:
      contents: write
      
    steps:
      - name: Pull Image
        run: docker pull cvedia/rt:latest-nvidia

      - name: Save Image to Tar
        run: docker save cvedia/rt:latest-nvidia -o cvedia_rt_nvidia.tar

      - name: Compress Image
        run: gzip cvedia_rt_nvidia.tar

      - name: Create Release and Upload
        uses: softprops/action-gh-release@v1
        with:
          files: cvedia_rt_nvidia.tar.gz
          tag_name: v1.0.${{ github.run_number }}
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
